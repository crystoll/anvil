{
	"name": "anvil",
	"version": "0.3.0",
	"description": "Multi-pane terminal interface for local-first AI development workflows",
	"license": "MIT",
	"author": "crystoll",
	"repository": {
		"type": "git",
		"url": "https://github.com/crystoll/anvil"
	},
	"keywords": [
		"ai",
		"cli",
		"local-first",
		"ollama",
		"agent",
		"tools"
	],
	"files": [
		"dist"
	],
	"type": "module",
	"bin": {
		"anvil": "./dist/main.js"
	},
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "tsx src/main.ts",
		"dev:simple": "tsx src/cli.ts",
		"dev:tui": "tsx src/tui/app.tsx",
		"build": "tsup",
		"prepare": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check . && oxlint",
		"format": "biome format --write . && dprint fmt",
		"format:md": "dprint fmt",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@mozilla/readability": "0.6.0",
		"anvil": "link:",
		"ink": "^7.1.0",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^6.0.0",
		"js-yaml": "5.1.0",
		"linkedom": "0.18.9",
		"neverthrow": "8.2.0",
		"react": "^19.2.7",
		"remeda": "2.21.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/node": "22.20.0",
		"@types/react": "^19.2.17",
		"dprint": "0.47.5",
		"msw": "2.14.6",
		"oxlint": "1.71.0",
		"tsup": "8.5.1",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vite": "^6.4.3",
		"vitest": "4.1.9"
	}
}
